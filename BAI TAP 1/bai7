class Student:
    def __init__(self, ten, diem):
        """
        Hàm khởi tạo (Constructor) để thiết lập thông tin ban đầu
        """
        self.ten = ten
        self.diem = diem

    def hien_thi_thong_tin(self):
        """
        Phương thức để in thông tin sinh viên
        """
        print(f"Sinh viên: {self.ten} - Điểm: {self.diem}")
student1 = Student("Nguyễn Việt Hoàng", 8.5)
student2 = Student("Vũ Xuân Hung", 9.0)
print("Thông tin danh sách sinh viên:")
student1.hien_thi_thong_tin()
student2.hien_thi_thong_tin()
